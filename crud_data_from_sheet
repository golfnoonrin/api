        <h4>Python:</h4>
        <pre style="background: #f4f4f4; padding: 10px; border-radius: 5px; overflow-x: auto;">
import requests
import json

url = "https://script.google.com/macros/s/your-id/exec"
data = {
    "token": "your-token",
    "sheetName": "Sheet1",
    "options": {"limit": 10}
}

response = requests.post(url, json=data)
print(response.json())</pre>

        <button class="btn btn-secondary" onclick="closeModal()" style="margin-top: 20px;">ปิด</button>
      </div>
    </div>

    <script>
      let filterCount = 0;
      let startTime = 0;

      // เพิ่ม filter
      function addFilter() {
        const container = document.getElementById('filtersContainer');
        filterCount++;
        
        const filterDiv = document.createElement('div');
        filterDiv.className = 'filter-item';
        filterDiv.id = `filter-${filterCount}`;
        
        filterDiv.innerHTML = `
          <input type="text" class="filter-key" placeholder="ชื่อคอลัมน์ (เช่น name)">
          <input type="text" class="filter-value" placeholder="ค่าที่ต้องการกรอง">
          <button type="button" onclick="removeFilter(${filterCount})">ลบ</button>
        `;
        
        container.appendChild(filterDiv);
      }

      // ลบ filter
      function removeFilter(id) {
        const filterDiv = document.getElementById(`filter-${id}`);
        if (filterDiv) {
          filterDiv.remove();
        }
      }

      // ดึง API URL
      function getApiUrl() {
        if (google && google.script && google.script.run) {
          document.getElementById('loadingStatus').textContent = 'กำลังดึง URL...';
          document.getElementById('loading').style.display = 'block';
          
          google.script.run.withSuccessHandler(function(url) {
            document.getElementById('apiUrl').textContent = url;
            document.getElementById('apiUrlInput').value = url;
            document.getElementById('loading').style.display = 'none';
          }).withFailureHandler(function(error) {
            document.getElementById('loading').style.display = 'none';
            alert('Error: ' + error);
          }).getDeployedUrl();
        } else {
          const demoUrl = prompt('กรุณาใส่ API URL (จาก Google Apps Script):');
          if (demoUrl) {
            document.getElementById('apiUrl').textContent = demoUrl;
            document.getElementById('apiUrlInput').value = demoUrl;
          }
        }
      }

      // ทดสอบ API
      function testApi() {
        const apiUrl = document.getElementById('apiUrlInput').value;
        if (!apiUrl) {
          alert('กรุณากรอก API URL');
          return;
        }

        startTime = Date.now();
        document.getElementById('loading').style.display = 'block';
        document.getElementById('loadingStatus').textContent = 'กำลังทดสอบการเชื่อมต่อ...';

        const callbackName = 'testCallback_' + Date.now();
        
        window[callbackName] = function(response) {
          const endTime = Date.now();
          document.getElementById('loading').style.display = 'none';
          
          if (response && response.success) {
            alert('✅ API เชื่อมต่อสำเร็จ!\n' + 
                  'Message: ' + response.message + '\n' +
                  'Response time: ' + (endTime - startTime) + 'ms');
          } else {
            alert('⚠️ API ตอบกลับ:\n' + JSON.stringify(response, null, 2));
          }
          
          delete window[callbackName];
          if (script.parentNode) script.parentNode.removeChild(script);
        };

        const script = document.createElement('script');
        script.src = apiUrl + '?callback=' + callbackName;
        script.onerror = function() {
          document.getElementById('loading').style.display = 'none';
          alert('❌ ไม่สามารถเชื่อมต่อ API ได้');
          delete window[callbackName];
        };
        
        document.body.appendChild(script);

        setTimeout(() => {
          if (window[callbackName]) {
            document.getElementById('loading').style.display = 'none';
            alert('⏰ การเชื่อมต่อหมดเวลา');
            delete window[callbackName];
            if (script.parentNode) script.parentNode.removeChild(script);
          }
        }, 10000);
      }

      // สร้าง payload
      function buildPayload() {
        const filters = {};
        const filterItems = document.querySelectorAll('.filter-item');
        
        filterItems.forEach(item => {
          const key = item.querySelector('.filter-key').value;
          const value = item.querySelector('.filter-value').value;
          if (key && value) {
            filters[key] = value;
          }
        });

        const options = {};
        
        const limit = document.getElementById('limit').value;
        if (limit) options.limit = parseInt(limit);
        
        const offset = document.getElementById('offset').value;
        if (offset) options.offset = parseInt(offset);
        
        if (Object.keys(filters).length > 0) {
          options.filters = filters;
        }

        return {
          token: document.getElementById('token').value,
          sheetName: document.getElementById('sheetName').value,
          id: document.getElementById('id').value || undefined,
          options: options
        };
      }

      // ดึงข้อมูล
      function fetchData(useJsonp = true) {
        if (!document.getElementById('token').value || !document.getElementById('sheetName').value) {
          alert('กรุณากรอก Token และเลือก Sheet Name');
          return;
        }

        const apiUrl = document.getElementById('apiUrlInput').value;
        if (!apiUrl) {
          alert('กรุณากรอก API URL');
          return;
        }

        startTime = Date.now();
        document.getElementById('loading').style.display = 'block';
        document.getElementById('loadingStatus').textContent = useJsonp ? 'กำลังเรียกข้อมูลแบบ JSONP...' : 'กำลังเรียกข้อมูล...';
        document.getElementById('error').style.display = 'none';
        document.getElementById('stats').style.display = 'none';

        if (useJsonp) {
          // ใช้ JSONP
          const payload = buildPayload();
          const callbackName = 'jsonpCallback_' + Date.now();
          
          window[callbackName] = function(response) {
            handleResponse(response);
            delete window[callbackName];
            if (script.parentNode) script.parentNode.removeChild(script);
          };

          const script = document.createElement('script');
          const dataStr = encodeURIComponent(JSON.stringify(payload));
          script.src = apiUrl + '?callback=' + callbackName + '&data=' + dataStr;
          
          script.onerror = function() {
            document.getElementById('loading').style.display = 'none';
            showError('เกิดข้อผิดพลาดในการโหลดสคริปต์');
            delete window[callbackName];
          };
          
          document.body.appendChild(script);

          setTimeout(() => {
            if (window[callbackName]) {
              document.getElementById('loading').style.display = 'none';
              showError('การเรียกข้อมูลหมดเวลา');
              delete window[callbackName];
              if (script.parentNode) script.parentNode.removeChild(script);
            }
          }, 30000);

        } else {
          // ใช้ fetch (อาจมี CORS error)
          fetch(apiUrl, {
            method: 'POST',
            mode: 'no-cors',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(buildPayload())
          })
          .then(response => {
            document.getElementById('loading').style.display = 'none';
            document.getElementById('status').textContent = '202';
            document.getElementById('message').textContent = 'Request sent (CORS mode)';
            document.getElementById('count').textContent = '?';
            document.getElementById('tableBody').innerHTML = `
              <tr>
                <td colspan="2" style="text-align: center; padding: 40px;">
                  ⚠️ CORS Error: Google Apps Script ไม่รองรับ CORS<br>
                  <button class="btn btn-success" onclick="fetchData(true)" style="margin-top: 10px;">
                    ลองใช้ JSONP แทน
                  </button>
                </td>
              </tr>
            `;
          })
          .catch(error => {
            document.getElementById('loading').style.display = 'none';
            showError('Error: ' + error.message);
          });
        }
      }

      // จัดการ response
      function handleResponse(response) {
        const endTime = Date.now();
        document.getElementById('loading').style.display = 'none';
        
        try {
          console.log('Response received:', response);
          
          document.getElementById('status').textContent = response.code || 200;
          document.getElementById('message').textContent = response.message || '-';
          
          if (response.success) {
            const data = response.data || [];
            document.getElementById('count').textContent = data.length;
            displayData(data);
            
            // แสดงสถิติ
            document.getElementById('stats').style.display = 'flex';
            document.getElementById('responseTime').textContent = endTime - startTime;
            document.getElementById('dataSize').textContent = 
              (new TextEncoder().encode(JSON.stringify(data)).length / 1024).toFixed(2);
          } else {
            showError(response.message || 'Unknown error');
          }
        } catch (e) {
          showError('Error parsing response: ' + e.message);
        }
      }

      // แสดงข้อมูล
      function displayData(data) {
        const tableBody = document.getElementById('tableBody');
        const tableHeader = document.getElementById('tableHeader');
        
        if (!data || data.length === 0) {
          tableBody.innerHTML = `
            <tr>
              <td colspan="2" style="text-align: center; padding: 40px; color: #666;">
                <span style="font-size: 48px;">🔍</span><br>
                ไม่พบข้อมูล
              </td>
            </tr>
          `;
          return;
        }

        // สร้าง headers
        const headers = Object.keys(data[0]);
        tableHeader.innerHTML = '<th>#</th>';
        headers.forEach(header => {
          tableHeader.innerHTML += `<th>${header}</th>`;
        });

        // แสดงข้อมูล
        tableBody.innerHTML = '';
        data.forEach((item, index) => {
          let row = '<tr>';
          row += `<td>${index + 1}</td>`;
          headers.forEach(header => {
            let value = item[header] || '-';
            // ถ้าค่ายาวเกินไปให้ตัด
            if (value.length > 50) value = value.substring(0, 50) + '...';
            row += `<td title="${item[header] || ''}">${value}</td>`;
          });
          row += '</tr>';
          tableBody.innerHTML += row;
        });
      }

      // แสดง error
      function showError(message) {
        const errorDiv = document.getElementById('error');
        errorDiv.textContent = message;
        errorDiv.style.display = 'block';
        
        document.getElementById('status').textContent = 'Error';
        document.getElementById('message').textContent = message;
        document.getElementById('count').textContent = '0';
        
        document.getElementById('tableBody').innerHTML = `
          <tr>
            <td colspan="2" style="text-align: center; padding: 40px; color: #666;">
              <span style="font-size: 48px;">❌</span><br>
              ${message}
            </td>
          </tr>
        `;
      }

      // ล้างฟอร์ม
      function clearForm() {
        document.getElementById('token').value = '';
        document.getElementById('sheetName').value = '';
        document.getElementById('id').value = '';
        document.getElementById('limit').value = '';
        document.getElementById('offset').value = '0';
        document.getElementById('filtersContainer').innerHTML = '';
        document.getElementById('error').style.display = 'none';
        document.getElementById('stats').style.display = 'none';
        
        document.getElementById('status').textContent = '-';
        document.getElementById('message').textContent = '-';
        document.getElementById('count').textContent = '0';
        
        document.getElementById('tableHeader').innerHTML = '<th>#</th><th>ข้อมูล</th>';
        document.getElementById('tableBody').innerHTML = `
          <tr>
            <td colspan="2" style="text-align: center; padding: 40px; color: #666;">
              <span style="font-size: 48px;">📭</span><br>
              ยังไม่มีข้อมูล กรุณาดึงข้อมูลก่อน
            </td>
          </tr>
        `;
        
        addFilter(); // เพิ่ม filter เริ่มต้น
      }

      // แสดงตัวอย่างโค้ด
      function showSampleCode() {
        document.getElementById('codeModal').style.display = 'block';
      }

      // ปิด modal
      function closeModal() {
        document.getElementById('codeModal').style.display = 'none';
      }

      // เริ่มต้น
      window.onload = function() {
        addFilter(); // เพิ่ม filter เริ่มต้น
      };
    </script>
  </body>
</html>

