<!DOCTYPE html>
<html>
  <head>
    <base target="_top">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Google Sheets API - Apps Script</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        padding: 20px;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        background: white;
        border-radius: 15px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        overflow: hidden;
      }

      .header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 30px;
        text-align: center;
      }

      .header h1 {
        font-size: 2.5em;
        margin-bottom: 10px;
      }

      .header p {
        font-size: 1.1em;
        opacity: 0.9;
      }

      .content {
        padding: 30px;
      }

      .setup-section {
        background: #f0f4ff;
        padding: 20px;
        border-radius: 10px;
        margin-bottom: 30px;
        border-left: 4px solid #667eea;
      }

      .setup-section h3 {
        color: #333;
        margin-bottom: 15px;
      }

      .api-url-box {
        background: #1a1a1a;
        color: #00ff00;
        padding: 15px;
        border-radius: 5px;
        margin: 15px 0;
        word-break: break-all;
        font-family: monospace;
        font-size: 14px;
      }

      .form-section {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 10px;
        margin-bottom: 30px;
      }

      .form-section h2 {
        color: #333;
        margin-bottom: 20px;
        font-size: 1.5em;
      }

      .form-group {
        margin-bottom: 15px;
      }

      label {
        display: block;
        margin-bottom: 5px;
        color: #555;
        font-weight: 500;
      }

      input, select, textarea {
        width: 100%;
        padding: 10px;
        border: 2px solid #ddd;
        border-radius: 5px;
        font-size: 16px;
        transition: border-color 0.3s;
      }

      input:focus, select:focus, textarea:focus {
        outline: none;
        border-color: #667eea;
      }

      .button-group {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 20px;
      }

      .btn {
        padding: 12px 24px;
        border: none;
        border-radius: 5px;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.3s;
        font-weight: 500;
      }

      .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
      }

      .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
      }

      .btn-success {
        background: #28a745;
        color: white;
      }

      .btn-success:hover {
        background: #218838;
      }

      .btn-secondary {
        background: #6c757d;
        color: white;
      }

      .btn-secondary:hover {
        background: #5a6268;
      }

      .btn-info {
        background: #17a2b8;
        color: white;
      }

      .btn-info:hover {
        background: #138496;
      }

      .result-section {
        background: white;
        border: 1px solid #ddd;
        border-radius: 10px;
        padding: 20px;
      }

      .result-section h2 {
        color: #333;
        margin-bottom: 20px;
      }

      .response-info {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 5px;
        margin-bottom: 20px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 10px;
      }

      .info-item {
        padding: 10px;
        background: white;
        border-radius: 5px;
        border-left: 3px solid #667eea;
      }

      .info-item strong {
        color: #667eea;
        display: block;
        margin-bottom: 5px;
      }

      .table-container {
        overflow-x: auto;
        max-height: 400px;
        overflow-y: auto;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      th, td {
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid #ddd;
      }

      th {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        font-weight: 500;
        position: sticky;
        top: 0;
      }

      tr:hover {
        background-color: #f5f5f5;
      }

      .error-message {
        background: #f8d7da;
        color: #721c24;
        padding: 15px;
        border-radius: 5px;
        margin-bottom: 20px;
        border-left: 4px solid #dc3545;
      }

      .loading {
        display: none;
        text-align: center;
        padding: 40px;
      }

      .spinner {
        border: 4px solid #f3f3f3;
        border-top: 4px solid #667eea;
        border-radius: 50%;
        width: 50px;
        height: 50px;
        animation: spin 1s linear infinite;
        margin: 0 auto 20px;
      }

      @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
      }

      .footer {
        text-align: center;
        padding: 20px;
        background: #f8f9fa;
        border-top: 1px solid #ddd;
        color: #666;
      }

      .note {
        background: #fff3cd;
        color: #856404;
        padding: 10px;
        border-radius: 5px;
        margin: 10px 0;
        border-left: 4px solid #ffc107;
        font-size: 14px;
      }

      .filter-item {
        display: flex;
        gap: 10px;
        margin-bottom: 10px;
        align-items: center;
      }

      .filter-item input {
        flex: 1;
      }

      .filter-item button {
        padding: 10px 15px;
        background: #dc3545;
        color: white;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        white-space: nowrap;
      }

      .filter-item button:hover {
        background: #c82333;
      }

      .add-filter {
        margin-top: 10px;
        padding: 10px 15px;
        background: #28a745;
        color: white;
        border: none;
        border-radius: 5px;
        cursor: pointer;
      }

      .add-filter:hover {
        background: #218838;
      }

      .stats {
        display: flex;
        gap: 20px;
        margin-top: 10px;
        padding: 10px;
        background: #e9ecef;
        border-radius: 5px;
      }

      .stats span {
        font-weight: bold;
        color: #667eea;
      }

      @media (max-width: 768px) {
        .button-group {
          flex-direction: column;
        }
        
        .btn {
          width: 100%;
        }
        
        .filter-item {
          flex-wrap: wrap;
        }
        
        .filter-item button {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>📊 Google Sheets API</h1>
        <p>ด้วย Google Apps Script (doPost) - รองรับ JSONP</p>
      </div>

      <div class="content">
        <div class="setup-section">
          <h3>🔧 การตั้งค่าเบื้องต้น</h3>
          <ol style="margin-left: 20px; margin-bottom: 15px;">
            <li>รัน <code>setSpreadsheetId('your-spreadsheet-id')</code> ใน Apps Script Editor</li>
            <li>รัน <code>setApiToken('your-token')</code> เพื่อตั้งค่า Token</li>
            <li>คลิก Deploy > New deployment > Web App</li>
            <li>ตั้งค่า Execute as: "Me", Access: "Anyone"</li>
            <li>คัดลอก URL ที่ได้มาวางด้านล่าง</li>
          </ol>
          
          <div class="api-url-box" id="apiUrl">
            คลิกปุ่ม "Get URL" เพื่อดู API URL
          </div>
          
          <div class="button-group">
            <button class="btn btn-info" onclick="getApiUrl()">
              🔗 Get API URL
            </button>
            <button class="btn btn-secondary" onclick="testApi()">
              🧪 Test API Connection
            </button>
          </div>
        </div>

        <div class="note">
          <strong>💡 หมายเหตุ:</strong> Google Apps Script ไม่รองรับ CORS เต็มรูปแบบ 
          ดังนั้นเราจะใช้วิธี JSONP ในการเรียกข้อมูล
        </div>

        <div class="form-section">
          <h2>⚙️ ทดสอบเรียก API</h2>

          <div class="form-group">
            <label for="apiUrlInput">API URL:</label>
            <input type="url" id="apiUrlInput" placeholder="https://script.google.com/macros/s/.../exec">
          </div>

          <div class="form-group">
            <label for="token">Token *</label>
            <input type="password" id="token" value="test-token-123" placeholder="กรอก API Token">
          </div>

          <div class="form-group">
            <label for="sheetName">Sheet Name *</label>
            <select id="sheetName">
              <option value="">เลือก Sheet</option>
              <option value="Sheet1" selected>Sheet1</option>
              <option value="Sheet2">Sheet2</option>
              <option value="Sheet3">Sheet3</option>
            </select>
          </div>

          <div class="form-group">
            <label for="id">ID (ค้นหาตาม ID)</label>
            <input type="text" id="id" placeholder="กรองตาม ID (ไม่บังคับ)">
          </div>

          <div class="form-group">
            <label>⚙️ ตัวเลือกเพิ่มเติม</label>
            <div style="margin-left: 20px; margin-top: 10px;">
              <div class="form-group">
                <label for="limit">Limit (จำนวนข้อมูล):</label>
                <input type="number" id="limit" min="1" placeholder="ไม่ระบุ = ดึงทั้งหมด">
              </div>
              
              <div class="form-group">
                <label for="offset">Offset (เริ่มจาก):</label>
                <input type="number" id="offset" min="0" value="0">
              </div>

              <div class="form-group">
                <label>🔍 ตัวกรองเพิ่มเติม:</label>
                <div id="filtersContainer"></div>
                <button type="button" class="add-filter" onclick="addFilter()">
                  ➕ เพิ่มตัวกรอง
                </button>
              </div>
            </div>
          </div>

          <div class="button-group">
            <button class="btn btn-primary" onclick="fetchData()">
              🔍 ดึงข้อมูล
            </button>
            <button class="btn btn-success" onclick="fetchData(true)">
              📊 ดึงข้อมูล (JSONP)
            </button>
            <button class="btn btn-secondary" onclick="clearForm()">
              🗑️ ล้างฟอร์ม
            </button>
            <button class="btn btn-info" onclick="showSampleCode()">
              📋 ตัวอย่างโค้ด
            </button>
          </div>
        </div>

        <div id="loading" class="loading">
          <div class="spinner"></div>
          <p>กำลังโหลดข้อมูล...</p>
          <p style="font-size: 14px; color: #666;" id="loadingStatus"></p>
        </div>

        <div id="error" class="error-message" style="display: none;"></div>

        <div class="result-section">
          <h2>📋 ผลลัพธ์</h2>
          
          <div class="response-info">
            <div class="info-item">
              <strong>Status Code:</strong>
              <span id="status">-</span>
            </div>
            <div class="info-item">
              <strong>Message:</strong>
              <span id="message">-</span>
            </div>
            <div class="info-item">
              <strong>จำนวนข้อมูล:</strong>
              <span id="count">0</span>
            </div>
          </div>

          <div class="table-container">
            <table id="resultTable">
              <thead>
                <tr id="tableHeader">
                  <th>#</th>
                  <th>ข้อมูล</th>
                </tr>
              </thead>
              <tbody id="tableBody">
                <tr>
                  <td colspan="2" style="text-align: center; padding: 40px; color: #666;">
                    <span style="font-size: 48px;">📭</span><br>
                    ยังไม่มีข้อมูล กรุณาดึงข้อมูลก่อน
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="stats" id="stats" style="display: none;">
            <div>⏱️ เวลาที่ใช้: <span id="responseTime">0</span> ms</div>
            <div>📦 ขนาดข้อมูล: <span id="dataSize">0</span> KB</div>
          </div>
        </div>
      </div>

      <div class="footer">
        <p>Google Apps Script API Demo | doPost() with JSONP Support | v2.0</p>
      </div>
    </div>

    <!-- Modal สำหรับแสดงตัวอย่างโค้ด -->
    <div id="codeModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000;">
      <div style="background: white; max-width: 600px; margin: 50px auto; padding: 20px; border-radius: 10px;">
        <h3 style="margin-bottom: 20px;">📋 ตัวอย่างการเรียก API</h3>
        
        <h4>JavaScript (JSONP):</h4>
        <pre style="background: #f4f4f4; padding: 10px; border-radius: 5px; overflow-x: auto;">
